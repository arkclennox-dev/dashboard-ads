NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (server + browser). Leave blank to run in demo mode (in-memory data).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Long random string used to hash API keys before storing.
API_KEY_SECRET=change-me-to-a-long-random-string

# Optional analytics
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# Meta Marketing API — auto-sync ad spend dari Meta Ads Manager
# Dapatkan dari Meta Business Manager > System Users > Generate Token (permission: ads_read)
META_ACCESS_TOKEN=
# Format: act_XXXXXXXXXX
META_AD_ACCOUNT_ID=
